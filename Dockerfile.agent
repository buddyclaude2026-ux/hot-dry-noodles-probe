FROM python:3.9-slim

WORKDIR /app

# Install ping (required for latency monitor)
RUN apt-get update && apt-get install -y iputils-ping && rm -rf /var/lib/apt/lists/*

# Install dependencies
COPY requirements.txt .
RUN pip install --no-cache-dir requests psutil

# Copy source code (Agent needs web/agent.py)
COPY . .

# Environment Defaults
ENV SERVER_URL="http://heihei-core:8081/api/v1/report"
ENV AGENT_NAME="Docker-Agent"

# Clean Command (Arguments can be overridden in compose)
# We assume web/agent.py exists at /app/web/agent.py
CMD ["python3", "web/agent.py", "--server", "http://heihei-core:8081/api/v1/report", "--db-path", "/app/heihei.db", "--name", "Docker-Agent"]
